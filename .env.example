# NSW Fuel Check API credentials
# Register at https://api.nsw.gov.au/ for your own keys
NSW_FUEL_KEY=your_api_key_here
NSW_FUEL_SECRET=your_api_secret_here

# Admin token for POST /api/refresh (required)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=generate_a_random_secret_here

# Optional configuration (defaults shown)
# SCHEDULER_INTERVAL_MS=21600000   # 6 hours
# COOLDOWN_MS=300000               # 5 minutes
# PORT=3000
# ORIGIN=https://fuelnsw.yourdomain.com
# DATA_DIR=./data
