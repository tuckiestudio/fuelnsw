{
	"name": "ausfuel",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"dev:web": "npm run dev --workspace=web",
		"dev:dashboard": "npm run dev --workspace=dashboard",
		"build:web": "npm run build --workspace=web",
		"build:dashboard": "npm run build --workspace=dashboard",
		"preview:web": "npm run preview --workspace=web",
		"preview:dashboard": "npm run preview --workspace=dashboard",
		"check:web": "npm run check --workspace=web",
		"check:dashboard": "npm run check --workspace=dashboard",
		"import:history": "tsx scripts/import-history.ts",
		"import:history:dry": "tsx scripts/import-history.ts --dry-run",
		"import:history:api": "tsx scripts/import-history.ts --api-only",
		"import:history:xlsx": "tsx scripts/import-history.ts --xlsx-only"
	},
	"devDependencies": {
		"tsx": "^4.19.0"
	}
}
